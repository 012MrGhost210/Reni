import openpyxl
from openpyxl.utils.cell import get_column_letter
from datetime import datetime, date
import os

# !!! СЮДА ВСТАВЬ СВОЙ ПУТЬ К ИСХОДНОМУ ФАЙЛУ !!!
path_to_source = r"C:\Users\YourName\Desktop\Твой_файл.xlsx" 

# !!! СЮДА ВСТАВЬ ПУТЬ ДЛЯ СОХРАНЕНИЯ НОВОГО ФАЙЛА !!!
# Например: r"C:\Users\YourName\Desktop\Новая_папка\Активные_сделки.xlsx"
path_to_save = r"C:\Users\YourName\Desktop\Активные_сделки.xlsx" 

# Имя листа, где лежат данные
SHEET_NAME = "Расчет доходности" 

def main():
    # 1. Проверяем, существует ли исходный файл
    if not os.path.exists(path_to_source):
        print(f"Ошибка: Исходный файл не найден по пути {path_to_source}")
        return

    # 2. Проверяем, существует ли папка для сохранения (если нет - создаем)
    save_dir = os.path.dirname(path_to_save)
    if save_dir and not os.path.exists(save_dir):
        print(f"Папка для сохранения не найдена. Создаю: {save_dir}")
        os.makedirs(save_dir)

    # 3. Открываем исходный файл (только для чтения данных)
    print("Открываю исходный файл...")
    wb_source = openpyxl.load_workbook(path_to_source, data_only=True)
    
    if SHEET_NAME not in wb_source.sheetnames:
        print(f"Ошибка: Лист '{SHEET_NAME}' не найден в файле.")
        return
        
    sheet_source = wb_source[SHEET_NAME]
    
    # 4. Определяем заголовки (берем первую строку)
    headers = []
    for col in range(1, sheet_source.max_column + 1):
        cell_value = sheet_source.cell(row=1, column=col).value
        headers.append(cell_value)

    # Находим индексы нужных колонок (поиск по заголовкам)
    col_C_name = sheet_source.cell(row=1, column=3).value
    col_D_name = sheet_source.cell(row=1, column=4).value
    col_Z_name = sheet_source.cell(row=1, column=26).value
    
    # Если в первой строке нет названий (пусто), то используем стандартные имена
    if not col_C_name:
        col_C_name = "Дата размещения"
    if not col_D_name:
        col_D_name = "Дата окончания"
    if not col_Z_name:
        col_Z_name = "Ставка"

    print(f"Найдены столбцы: '{col_C_name}' (C), '{col_D_name}' (D), '{col_Z_name}' (Z)")

    # 5. Создаем новую книгу для результатов
    wb_result = openpyxl.Workbook()
    
    # Удаляем дефолтный лист "Sheet", чтобы создать свои
    default_sheet = wb_result.active
    wb_result.remove(default_sheet)
    
    # Создаем два листа
    sheet_7plus = wb_result.create_sheet("Срок_от_7_дней")
    sheet_less7 = wb_result.create_sheet("Срок_меньше_7")
    
    # 6. Функция для копирования строки (значений) на нужный лист
    def copy_row_to_sheet(target_sheet, source_row_data, target_row_num):
        # source_row_data - это список значений ячеек из исходного файла
        for col_idx, value in enumerate(source_row_data, start=1):
            target_sheet.cell(row=target_row_num, column=col_idx, value=value)

    # Копируем заголовки (первая строка) в оба новых листа
    header_row_data = []
    for col in range(1, sheet_source.max_column + 1):
        header_row_data.append(sheet_source.cell(row=1, column=col).value)
    
    copy_row_to_sheet(sheet_7plus, header_row_data, 1)
    copy_row_to_sheet(sheet_less7, header_row_data, 1)

    # Счетчики для строк, куда будем вставлять данные (начинаем со 2-й, т.к. 1-я занята заголовками)
    row_7plus = 2
    row_less7 = 2

    # 7. Получаем сегодняшнюю дату
    today = datetime.now().date()
    print(f"Сегодня: {today}")

    # 8. Проходим по всем строкам исходного листа (начиная со 2-й, чтобы пропустить заголовки)
    print("Обрабатываю сделки...")
    processed_count = 0
    active_count = 0

    for row in range(2, sheet_source.max_row + 1):
        # Забираем значения из колонок C (дата размещения) и D (дата окончания)
        date_start = sheet_source.cell(row=row, column=3).value
        date_end = sheet_source.cell(row=row, column=4).value
        
        # Проверяем, что даты не пустые и являются объектами datetime/date
        if not isinstance(date_start, (datetime, date)) or not isinstance(date_end, (datetime, date)):
            continue  # Пропускаем строки без дат
            
        # Приводим к типу date (если это datetime, берем только дату)
        if isinstance(date_start, datetime):
            date_start = date_start.date()
        if isinstance(date_end, datetime):
            date_end = date_end.date()
            
        # Проверяем активность: дата окончания >= сегодня
        if date_end >= today:
            active_count += 1
            # Считаем разницу в днях
            delta = (date_end - date_start).days
            
            # Собираем все значения ячеек строки в список (чтобы скопировать целиком)
            row_data = []
            for col in range(1, sheet_source.max_column + 1):
                row_data.append(sheet_source.cell(row=row, column=col).value)
            
            # Распределяем по листам
            if delta >= 7:
                copy_row_to_sheet(sheet_7plus, row_data, row_7plus)
                row_7plus += 1
            else:
                copy_row_to_sheet(sheet_less7, row_data, row_less7)
                row_less7 += 1
                
        processed_count += 1

    # 9. Сохраняем новый файл по указанному пути
    wb_result.save(path_to_save)
    
    print(f"\n✅ Готово!")
    print(f"Всего обработано строк: {processed_count}")
    print(f"Найдено активных сделок: {active_count}")
    print(f"  - Срок >= 7 дней: {row_7plus - 2} шт. (лист 'Срок_от_7_дней')")
    print(f"  - Срок < 7 дней: {row_less7 - 2} шт. (лист 'Срок_меньше_7')")
    print(f"\n📁 Новый файл сохранен как: {path_to_save}")
    print("🔒 Исходный файл остался без изменений.")

if __name__ == "__main__":
    main()
