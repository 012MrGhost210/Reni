def load_keywords_and_paths():
    """
    Загружает ключевые слова и соответствующие пути из Excel файла
    Ожидает структуру:
    Столбец A: ключевое слово
    Столбец B: путь для поиска
    Столбец C: режим (YES - только последние файлы, NO/пусто - все файлы)
    
    Возвращает список словарей: [{'keyword': '...', 'path': '...', 'mode': 'YES/NO'}]
    """
    try:
        if not os.path.exists(KEYWORDS_EXCEL_FILE):
            print(f"Файл с ключевыми словами не найден: {KEYWORDS_EXCEL_FILE}")
            return []
        
        print(f"Загружаем ключевые слова из: {KEYWORDS_EXCEL_FILE}")
        
        # Читаем Excel файл
        df = pd.read_excel(KEYWORDS_EXCEL_FILE, sheet_name=KEYWORDS_EXCEL_SHEET, header=None)
        
        # Получаем значения из колонок A, B, C
        keywords_data = []
        for idx, row in df.iterrows():
            # Проверяем, что есть ключевое слово и путь
            if len(row) >= 2 and pd.notna(row[0]) and pd.notna(row[1]):
                keyword = str(row[0]).strip()
                path = str(row[1]).strip()
                
                # Режим фильтрации (столбец C)
                mode = 'NO'
                if len(row) >= 3 and pd.notna(row[2]):
                    mode = str(row[2]).strip().upper()
                
                if keyword and path and os.path.exists(path):
                    keywords_data.append({
                        'keyword': keyword,
                        'path': path,
                        'mode': mode
                    })
                elif keyword and path and not os.path.exists(path):
                    print(f"Путь не существует для ключевого слова '{keyword}': {path}")
        
        print(f"Загружено ключевых слов с путями: {len(keywords_data)}")
        
        return keywords_data
        
    except Exception as e:
        print(f"Ошибка при загрузке ключевых слов из Excel: {e}")
        import traceback
        traceback.print_exc()
        return []

def get_latest_files_by_pattern(directory, pattern, mode):
    """
    Получает список файлов в зависимости от режима:
    - Если mode = 'YES': только самый свежий файл для каждого шаблона
    - Если mode = 'NO' или другой: все файлы
    
    Возвращает список файлов
    """
    all_files = []
    pattern_lower = pattern.lower()
    
    try:
        for root, dirs, files in os.walk(directory):
            for file in files:
                file_lower = file.lower()
                
                # Проверяем наличие паттерна в имени файла
                if pattern_lower in file_lower:
                    file_path = Path(root) / file
                    all_files.append(file_path)
    except Exception as e:
        print(f"Ошибка при поиске в {directory}: {e}")
    
    if mode == 'YES' and all_files:
        # Группируем файлы по паттерну и берем самый свежий
        # В данном случае у нас один паттерн, но файлы могут быть в разных папках
        # Сортируем по дате изменения и берем самый свежий
        latest_file = max(all_files, key=lambda x: os.path.getmtime(x) if os.path.exists(x) else 0)
        return [latest_file]
    
    return all_files

def check_keyword_match(file_path, filename, keyword, case_sensitive):
    """
    Проверяет, содержит ли файл/путь указанное ключевое слово
    """
    if not case_sensitive:
        search_text = filename.lower() if SEARCH_IN_FILENAME_ONLY else str(file_path).lower()
        keyword = keyword.lower()
    else:
        search_text = filename if SEARCH_IN_FILENAME_ONLY else str(file_path)
    
    return keyword in search_text

def format_worksheet(worksheet, title, has_data=True):
    """
    Форматирует отдельный лист Excel
    """
    # Устанавливаем ширину столбцов
    column_widths = {
        'A': 40,   # Имя файла
        'B': 20,   # Тип файла
        'C': 25,   # Дата изменения
        'D': 100,  # Полный путь
        'E': 30,   # Ключевое слово
        'F': 30,   # Источник (папка поиска)
    }
    
    for col, width in column_widths.items():
        worksheet.column_dimensions[col].width = width
    
    # Форматируем заголовки
    header_font = Font(bold=True, color="FFFFFF", size=12)
    header_fill = PatternFill(start_color="4472C4", end_color="4472C4", fill_type="solid")
    
    headers = ["Имя файла", "Тип файла", "Дата изменения", "Полный путь", "Ключевое слово", "Папка поиска"]
    
    for col, header in enumerate(headers, 1):
        cell = worksheet.cell(row=1, column=col, value=header)
        cell.font = header_font
        cell.fill = header_fill
        cell.alignment = Alignment(horizontal='center', vertical='center')
    
    if has_data:
        # Делаем автофильтр
        worksheet.auto_filter.ref = f"A1:F{worksheet.max_row}"
        
        # Настраиваем стиль для гиперссылок
        hyperlink_font = Font(color="0563C1", underline="single")
        
        # Применяем стиль гиперссылок
        for row in range(2, worksheet.max_row + 1):
            path_cell = worksheet.cell(row=row, column=4)
            
            if CREATE_HYPERLINKS and path_cell.hyperlink:
                path_cell.font = hyperlink_font
                
                name_cell = worksheet.cell(row=row, column=1)
                name_cell.hyperlink = path_cell.hyperlink
                name_cell.font = hyperlink_font
        
        # Условное форматирование для дат
        date_column_letter = 'C'
        date_range = f"{date_column_letter}2:{date_column_letter}{worksheet.max_row}"
        
        today_fill = PatternFill(start_color="C6EFCE", end_color="C6EFCE", fill_type="solid")
        today_font = Font(color="006100")
        
        today_rule = FormulaRule(
            formula=[f'AND(${date_column_letter}2>=TODAY(), ${date_column_letter}2<TODAY()+1)'],
            fill=today_fill,
            font=today_font
        )
        worksheet.conditional_formatting.add(date_range, today_rule)
        
        old_fill = PatternFill(start_color="FFC7CE", end_color="FFC7CE", fill_type="solid")
        old_font = Font(color="9C0006")
        
        old_rule = FormulaRule(
            formula=[f'${date_column_letter}2<TODAY()-30'],
            fill=old_fill,
            font=old_font
        )
        worksheet.conditional_formatting.add(date_range, old_rule)
    
    # Замораживаем первую строку
    worksheet.freeze_panes = "A2"

def create_file_hyperlink(file_path):
    """
    Создает корректную гиперссылку для файла
    """
    try:
        if not os.path.exists(file_path):
            return None
        
        abs_path = os.path.abspath(file_path)
        hyperlink_path = abs_path.replace('/', '\\')
        
        return hyperlink_path
    except:
        return None

def create_excel_report(files_data, keywords_data, output_path, total_processed):
    """
    Создает Excel файл с отдельными листами для каждого ключевого слова
    Сохраняет существующий лист "Глоссарий" если он есть
    """
    try:
        # Проверяем, существует ли уже файл
        file_exists = os.path.exists(output_path)
        
        if file_exists:
            # Загружаем существующий файл
            workbook = load_workbook(output_path)
            
            # Удаляем все листы кроме "Глоссарий"
            sheets_to_remove = []
            for sheet_name in workbook.sheetnames:
                if sheet_name != "Глоссарий":
                    sheets_to_remove.append(sheet_name)
            
            for sheet_name in sheets_to_remove:
                std = workbook[sheet_name]
                workbook.remove(std)
        else:
            # Создаем новую книгу
            workbook = Workbook()
            
            # Удаляем стандартный лист
            default_sheet = workbook.active
            workbook.remove(default_sheet)
            
            # Создаем лист "Глоссарий"
            workbook.create_sheet("Глоссарий")
        
        # Словарь для хранения файлов по ключевым словам
        keyword_files = {}
        
        # Распределяем файлы по ключевым словам
        for file_info in files_data:
            filename, file_type, mod_date, full_path, source_dir, keyword = file_info
            
            if keyword not in keyword_files:
                keyword_files[keyword] = []
            
            keyword_files[keyword].append([
                filename, file_type, mod_date, full_path, keyword, source_dir
            ])
        
        # Создаем листы для каждого ключевого слова
        keywords_list = [item['keyword'] for item in keywords_data]
        keywords_for_sheets = keywords_list[:MAX_KEYWORDS_FOR_SHEETS]
        
        print(f"\nСоздаем отдельные листы для {len(keywords_for_sheets)} ключевых слов:")
        
        for keyword in keywords_for_sheets:
            # Очищаем название листа от недопустимых символов
            sheet_name = re.sub(r'[\[\]\*\?\/\\]', '_', keyword)[:31]
            
            ws = workbook.create_sheet(sheet_name)
            files_for_keyword = keyword_files.get(keyword, [])
            
            # Заполняем лист
            for row_idx, row_data in enumerate(files_for_keyword, 2):
                for col_idx, value in enumerate(row_data, 1):
                    ws.cell(row=row_idx, column=col_idx, value=value)
                    
                    # Добавляем гиперссылку для полного пути
                    if col_idx == 4 and CREATE_HYPERLINKS:
                        hyperlink = create_file_hyperlink(value)
                        if hyperlink:
                            ws.cell(row=row_idx, column=col_idx).hyperlink = hyperlink
            
            format_worksheet(ws, sheet_name, bool(files_for_keyword))
            
            # Добавляем информацию о количестве
            info_row = len(files_for_keyword) + 3
            ws.cell(row=info_row, column=1, value=f"Найдено файлов: {len(files_for_keyword)}")
            ws.cell(row=info_row, column=1).font = Font(bold=True, size=12)
            
            print(f"   {keyword}: {len(files_for_keyword)} файлов")
        
        # Если ключевых слов больше MAX_KEYWORDS_FOR_SHEETS, создаем дополнительный лист
        if len(keywords_list) > MAX_KEYWORDS_FOR_SHEETS:
            ws_extra = workbook.create_sheet("Остальные ключевые слова")
            extra_keywords = keywords_list[MAX_KEYWORDS_FOR_SHEETS:]
            
            row_idx = 2
            for keyword in extra_keywords:
                ws_extra.cell(row=row_idx, column=1, value=keyword)
                count = len(keyword_files.get(keyword, []))
                ws_extra.cell(row=row_idx, column=2, value=count)
                row_idx += 1
            
            ws_extra.column_dimensions['A'].width = 40
            ws_extra.column_dimensions['B'].width = 20
            ws_extra.cell(row=1, column=1, value="Ключевое слово").font = Font(bold=True)
            ws_extra.cell(row=1, column=2, value="Количество файлов").font = Font(bold=True)
            ws_extra.freeze_panes = "A2"
            
            print(f"   Остальные ключевые слова: {len(extra_keywords)} шт.")
        
        # Создаем лист со статистикой
        ws_stats = workbook.create_sheet("Статистика")
        
        stats_data = [
            ["Параметр", "Значение"],
            ["Дата создания отчета", datetime.now().strftime('%Y-%m-%d %H:%M:%S')],
            ["Всего обработано файлов", total_processed],
            ["Всего файлов в отчете", len(files_data)],
            ["Всего ключевых слов", len(keywords_list)],
            ["Ключевых слов с отдельными листами", min(len(keywords_list), MAX_KEYWORDS_FOR_SHEETS)],
        ]
        
        stats_data.extend([
            ["", ""],
            ["Настройки поиска:", ""],
            ["Чувствительность к регистру", "Да" if CASE_SENSITIVE_SEARCH else "Нет"],
            ["Поиск только в именах файлов", "Да" if SEARCH_IN_FILENAME_ONLY else "Нет"],
            ["Гиперссылки", "Да" if CREATE_HYPERLINKS else "Нет"],
            ["", ""],
            ["СПИСОК ВСЕХ КЛЮЧЕВЫХ СЛОВ И ПУТЕЙ:", ""],
        ])
        
        # Добавляем информацию о ключевых словах и путях
        for item in keywords_data:
            stats_data.append([
                item['keyword'],
                f"Путь: {item['path']} (режим: {item['mode']})"
            ])
        
        # Заполняем статистику
        for row_idx, row_data in enumerate(stats_data, 1):
            for col_idx, value in enumerate(row_data, 1):
                cell = ws_stats.cell(row=row_idx, column=col_idx, value=value)
                if row_idx == 1:
                    cell.font = Font(bold=True)
                    cell.fill = PatternFill(start_color="4472C4", end_color="4472C4", fill_type="solid")
                    cell.font = Font(bold=True, color="FFFFFF")
        
        ws_stats.column_dimensions['A'].width = 30
        ws_stats.column_dimensions['B'].width = 80
        
        # Сохраняем файл
        workbook.save(output_path)
        return True
        
    except Exception as e:
        print(f"Ошибка при создании Excel отчета: {e}")
        import traceback
        traceback.print_exc()
        return False

def open_excel_file(file_path):
    try:
        os.startfile(file_path)
        return True
    except Exception as e:
        print(f"Не удалось открыть Excel файл: {e}")
        return False

def analyze_files():
    """
    Анализирует файлы на основе ключевых слов и соответствующих путей
    """
    excel_path = Path(OUTPUT_DIRECTORY) / EXCEL_FILENAME
    
    # Загружаем ключевые слова и пути
    keywords_data = load_keywords_and_paths()
    
    if not keywords_data:
        print("Нет ключевых слов для поиска!")
        return
    
    # Список для хранения данных
    all_files_data = []
    
    # Счетчики
    total_processed = 0
    
    print("=" * 80)
    print("АНАЛИЗ ФАЙЛОВ С ПРИВЯЗКОЙ КЛЮЧЕВЫХ СЛОВ К ПАПКАМ")
    print("=" * 80)
    
    print(f"Загружено ключевых слов: {len(keywords_data)}")
    print(f"Отчет будет сохранен: {excel_path}")
    print("-" * 80)
    
    # Обрабатываем каждое ключевое слово с его путем
    for item in keywords_data:
        keyword = item['keyword']
        source_dir = item['path']
        mode = item['mode']
        
        print(f"\nОбрабатываем ключевое слово: '{keyword}'")
        print(f"  Путь: {source_dir}")
        print(f"  Режим: {'только последние файлы' if mode == 'YES' else 'все файлы'}")
        
        # Получаем файлы для этого ключевого слова
        files = get_latest_files_by_pattern(source_dir, keyword, mode)
        
        keyword_file_count = 0
        for file_path in files:
            try:
                filename = file_path.name
                
                file_extension = file_path.suffix.lower()
                if file_extension:
                    file_type = file_extension.lstrip('.').upper()
                else:
                    file_type = "БЕЗ РАСШИРЕНИЯ"
                
                try:
                    mod_time = os.path.getmtime(file_path)
                    mod_date = datetime.fromtimestamp(mod_time).strftime('%Y-%m-%d %H:%M:%S')
                except:
                    mod_date = 'НЕДОСТУПНО'
                
                full_path = str(file_path.resolve())
                
                # Сохраняем информацию о файле
                all_files_data.append([
                    filename,
                    file_type,
                    mod_date,
                    full_path,
                    source_dir,
                    keyword
                ])
                
                keyword_file_count += 1
                total_processed += 1
                
            except Exception as e:
                print(f"  Ошибка при обработке файла {file_path}: {e}")
                continue
        
        print(f"  Найдено файлов: {keyword_file_count}")
    
    # Создаем Excel отчет
    if all_files_data:
        print("\n" + "-" * 80)
        print("СОЗДАНИЕ ОТЧЕТА...")
        
        success = create_excel_report(
            all_files_data,
            keywords_data,
            excel_path,
            total_processed
        )
        
        print("-" * 80)
        print("ИТОГОВЫЕ РЕЗУЛЬТАТЫ:")
        print(f"  Всего обработано файлов: {total_processed}")
        print(f"  Всего записей в отчете: {len(all_files_data)}")
        print(f"  Ключевых слов: {len(keywords_data)}")
        
        if success:
            print(f"\n  Excel отчет успешно создан: {excel_path}")
            
            if CREATE_HYPERLINKS:
                print(f"  Гиперссылки добавлены к именам файлов и путям")
            
            if OPEN_EXCEL_AFTER_CREATION:
                print(f"  Открываю Excel файл...")
                open_excel_file(excel_path)
        else:
            print("  Не удалось создать Excel отчет")
    else:
        print("\nНе найдено файлов.")
    
    print("=" * 80)

if __name__ == "__main__":
    analyze_files()
