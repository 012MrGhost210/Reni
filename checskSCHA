def check_today_files():
    """
    Проверяет наличие СЕГОДНЯШНИХ файлов в каждой папке
    """
    print("="*60)
    print("ПРОВЕРКА НАЛИЧИЯ СЕГОДНЯШНИХ ФАЙЛОВ")
    print("="*60)
    print(f"Дата проверки: {datetime.now().strftime('%d.%m.%Y')}")
    print("-"*60)
    
    today_start = datetime.now().replace(hour=0, minute=0, second=0, microsecond=0)
    all_today = True
    results = []
    
    for target in TARGETS:
        folder_path = os.path.join(source_root, target["path"])
        short_name = target["short_name"]
        search_pattern = target["search_pattern"]
        
        print(f"\n▶ {short_name}:")
        
        # Проверка существования папки
        if not os.path.exists(folder_path):
            print(f"  [ОШИБКА] Папка не найдена")
            all_today = False
            results.append({"company": short_name, "status": "error", "message": "папка не найдена"})
            continue
        
        # Сбор сегодняшних файлов
        today_files = []
        all_files = []
        
        for filename in os.listdir(folder_path):
            if search_pattern.lower() in filename.lower():
                file_path = os.path.join(folder_path, filename)
                if os.path.isfile(file_path):
                    mod_time = os.path.getmtime(file_path)
                    mod_date = datetime.fromtimestamp(mod_time)
                    file_size = os.path.getsize(file_path) / 1024  # в КБ
                    
                    file_info = {
                        "name": filename,
                        "path": file_path,
                        "date": mod_date,
                        "size_kb": round(file_size, 1)
                    }
                    
                    all_files.append(file_info)
                    
                    # Проверка, что файл сегодняшний
                    if mod_date >= today_start:
                        today_files.append(file_info)
        
        # Сортировка всех файлов по дате
        all_files.sort(key=lambda x: x["date"], reverse=True)
        
        if not all_files:
            print(f"  [ОШИБКА] Файлы с паттерном '{search_pattern}' не найдены")
            all_today = False
            results.append({"company": short_name, "status": "error", "message": "файлы не найдены"})
            continue
        
        if today_files:
            latest = today_files[0]
            print(f"  [OK] Найден сегодняшний файл: {latest['name']}")
            print(f"     Время: {latest['date'].strftime('%H:%M')}")
            print(f"     Размер: {latest['size_kb']} КБ")
            
            if len(today_files) > 1:
                print(f"     Всего сегодняшних файлов: {len(today_files)}")
            
            results.append({
                "company": short_name, 
                "status": "ok", 
                "today_count": len(today_files),
                "latest": latest
            })
        else:
            latest = all_files[0]
            days_old = (datetime.now() - latest["date"]).days
            
            print(f"  [ОШИБКА] Нет сегодняшних файлов! Самый свежий:")
            print(f"     От {latest['date'].strftime('%d.%m.%Y %H:%M')} ({days_old} дн. назад)")
            print(f"     {latest['name'][:80]}")
            print(f"     Размер: {latest['size_kb']} КБ")
            
            all_today = False
            results.append({
                "company": short_name, 
                "status": "missing", 
                "latest": latest,
                "days_old": days_old
            })
    
    # Итоговый отчет
    print("\n" + "="*60)
    print("ИТОГ ПРОВЕРКИ:")
    print("="*60)
    
    today_count = sum(1 for r in results if r.get("status") == "ok")
    missing_count = sum(1 for r in results if r.get("status") == "missing")
    error_count = sum(1 for r in results if r.get("status") == "error")
    
    print(f"Сегодняшние файлы есть: {today_count}")
    if missing_count > 0:
        print(f"Нет сегодняшних: {missing_count}")
    if error_count > 0:
        print(f"Ошибки: {error_count}")
    
    print("\n" + "-"*60)
    if all_today:
        print("РЕЗУЛЬТАТ: По всем компаниям есть сегодняшние файлы!")
    else:
        print("РЕЗУЛЬТАТ: Не по всем компаниям есть сегодняшние файлы. Требуется внимание.")
    
    return all_today, results

def quick_check():
    """Быстрая проверка только наличия сегодняшних файлов"""
    print("Быстрая проверка наличия сегодняшних файлов...")
    print("-"*40)
    
    today_start = datetime.now().replace(hour=0, minute=0, second=0, microsecond=0)
    
    for target in TARGETS:
        folder_path = os.path.join(source_root, target["path"])
        short_name = target["short_name"]
        search_pattern = target["search_pattern"]
        
        if not os.path.exists(folder_path):
            print(f"{short_name}: [ОШИБКА] папка не найдена")
            continue
        
        # Поиск сегодняшних файлов
        has_today = False
        latest_date = None
        latest_name = None
        
        for filename in os.listdir(folder_path):
            if search_pattern.lower() in filename.lower():
                file_path = os.path.join(folder_path, filename)
                if os.path.isfile(file_path):
                    mod_time = os.path.getmtime(file_path)
                    mod_date = datetime.fromtimestamp(mod_time)
                    
                    if latest_date is None or mod_date > latest_date:
                        latest_date = mod_date
                        latest_name = filename
                    
                    if mod_date >= today_start:
                        has_today = True
        
        if has_today:
            print(f"{short_name}: [OK] есть сегодняшний")
        elif latest_date:
            days_old = (datetime.now() - latest_date).days
            if days_old == 0:
                print(f"{short_name}: [ОШИБКА] есть только от сегодня {latest_date.strftime('%H:%M')}, но не подходит под паттерн?")
            else:
                print(f"{short_name}: [ОШИБКА] нет сегодняшних (самый свежий от {latest_date.strftime('%d.%m.%Y')})")
        else:
            print(f"{short_name}: [ОШИБКА] файлы не найдены")

if __name__ == "__main__":
    if len(sys.argv) > 1 and sys.argv[1] == "--quick":
