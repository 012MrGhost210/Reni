def clean_filename(filename):
    """
    Очищает имя файла от фигурных скобок и их содержимого
    Пример: "отчет{версия2}.xlsx" -> "отчет.xlsx"
            "отчет.xlsx" -> "отчет.xlsx"
    """
    name_parts = filename.rsplit('.', 1)
    if len(name_parts) == 2:
        name_without_ext, ext = name_parts[0], name_parts[1]
        # Удаляем всё, что находится в фигурных скобках, включая сами скобки
        cleaned_name = re.sub(r'\{[^}]*\}', '', name_without_ext)
        # Удаляем возможные лишние символы (например, двойные пробелы, подчёркивания в конце)
        cleaned_name = re.sub(r'\s+', ' ', cleaned_name).strip()
        cleaned_name = re.sub(r'[_\-\.]+$', '', cleaned_name)
        return f"{cleaned_name}.{ext}"
    return filename

def round_numeric_values(df):
    """
    Округляет все числовые значения в DataFrame до целых чисел
    """
    for col in df.columns:
        for row in range(len(df)):
            val = df.iloc[row, col]
            if pd.notna(val) and isinstance(val, (int, float)):
                # Если значение не NaN и является числом
                if not isinstance(val, bool):  # Не трогаем boolean значения
                    # Округляем до целого числа
                    df.iloc[row, col] = round(val)
    return df

def process_report(file_path, output_dir):
    """
    Обрабатывает один Excel-файл с отчётом
    """
    print(f"📄 Обработка: {file_path.name}")
    
    # Очищаем имя файла от фигурных скобок
    cleaned_filename = clean_filename(file_path.name)
    if cleaned_filename != file_path.name:
        print(f"   🧹 Очищено имя файла: '{file_path.name}' → '{cleaned_filename}'")
    
    output_path = output_dir / cleaned_filename
    
    # ПРОВЕРКА: если файл уже существует, пропускаем
    if output_path.exists():
        print(f"   ⏭️ Файл уже существует, пропускаем: {cleaned_filename}")
        return None
    
    # Загружаем файл
    df = pd.read_excel(file_path, sheet_name='Лист_1', header=None)
    
    # 1. Сдвигаем данные: вставляем пустую строку сверху
    empty_row = pd.DataFrame([[''] * df.shape[1]], columns=df.columns)
    df_new = pd.concat([empty_row, df], ignore_index=True)
    
    # 2. Меняем название на нужное в B2 (строка 2, колонка 2)
    if df_new.shape[0] > 1 and df_new.shape[1] > 1:
        old_value = df_new.iloc[1, 1]
        if pd.notna(old_value):
            print(f"   Старое значение в B2: '{old_value}'")
        df_new.iloc[1, 1] = "Сводный отчет по портфелям УК Первая"
        print(f"   ✅ Изменено B2 на: 'Сводный отчет по портфелям УК Первая'")
    
    # 3. Также меняем везде, где встречается любое из старых названий
    old_names = ["Сводный отчет по портфелям", "Сводный отчет по портфелю", "Сводный отчет"]
    for i in range(df_new.shape[0]):
        for j in range(df_new.shape[1]):
            if pd.notna(df_new.iloc[i, j]) and isinstance(df_new.iloc[i, j], str):
                for old_name in old_names:
                    if old_name in df_new.iloc[i, j]:
                        df_new.iloc[i, j] = "Сводный отчет по портфелям УК Первая"
                        break
    
    # 4. Округляем все числовые значения до целых чисел
    df_new = round_numeric_values(df_new)
    print(f"   🔢 Все числовые значения округлены до целых чисел")
    
    # 5. Находим начало таблицы (строку с заголовками)
    header_row_idx = None
    for i in range(df_new.shape[0]):
        row_values = df_new.iloc[i].astype(str).values
        if any("Портфель" in str(v) for v in row_values) and any("Эмитент" in str(v) for v in row_values):
            header_row_idx = i
            break
    
    if header_row_idx is None:
        print(f"   ⚠️ Не удалось найти заголовки таблицы в {file_path.name}")
        return None
    
    # 6. Находим конец таблицы
    last_data_row = header_row_idx
    for i in range(header_row_idx + 1, df_new.shape[0]):
        row = df_new.iloc[i]
        if all(pd.isna(cell) or str(cell).strip() == '' for cell in row):
            break
        row_str = ' '.join(str(cell) for cell in row if pd.notna(cell))
        if any(keyword in row_str for keyword in ['Руководитель', 'подпись', 'расшифровка', 'Дата', 'Баланс']):
            break
        last_data_row = i
    
    # 7. Формируем итоговую структуру
    result_rows = []
    
    # Пустая первая строка
    result_rows.append([''] * df_new.shape[1])
    
    # Шапка (все строки до таблицы)
    for i in range(1, header_row_idx):
        result_rows.append(df_new.iloc[i].tolist())
    
    # Пустая строка после шапки
    result_rows.append([''] * df_new.shape[1])
    
    # Таблица (заголовки + данные)
    for i in range(header_row_idx, last_data_row + 1):
        result_rows.append(df_new.iloc[i].tolist())
    
    # Создаём итоговый DataFrame
    max_cols = max(len(row) for row in result_rows) if result_rows else 0
    for row in result_rows:
        while len(row) < max_cols:
            row.append('')
    
    df_output = pd.DataFrame(result_rows)
    
    # Сохраняем в новую папку
    with pd.ExcelWriter(output_path, engine='openpyxl') as writer:
        df_output.to_excel(writer, sheet_name='Лист_1', index=False, header=False)
    
    # Принудительно исправляем через openpyxl и округляем числа
    wb = openpyxl.load_workbook(output_path)
    ws = wb['Лист_1']
    
    # Принудительно меняем ячейку B2 (строка 2, колонка 2)
    ws.cell(row=2, column=2).value = "Сводный отчет по портфелям УК Первая"
    
    # Дополнительное округление всех числовых значений в листе
    for row in range(1, ws.max_row + 1):
        for col in range(1, ws.max_column + 1):
            cell = ws.cell(row=row, column=col)
            if isinstance(cell.value, (int, float)) and not isinstance(cell.value, bool):
                # Округляем до целого числа
                cell.value = round(cell.value)
    
    # Удаляем пустые строки снизу
    for row in range(ws.max_row, 0, -1):
        is_empty = True
        for col in range(1, ws.max_column + 1):
            if ws.cell(row=row, column=col).value not in (None, '', 'None'):
                is_empty = False
                break
        if is_empty:
            ws.delete_rows(row)
        else:
            break
    
    wb.save(output_path)
    
    print(f"   ✅ Сохранён: {cleaned_filename}")
    return output_path

def process_all_reports(input_dir, output_dir):
    """
    Обрабатывает все Excel-файлы в папке
    """
    input_path = Path(input_dir)
    output_path = Path(output_dir)
    
    if not input_path.exists():
        print(f"❌ Папка не найдена: {input_dir}")
        return
    
    # Создаём папку для результатов, если её нет
    output_path.mkdir(parents=True, exist_ok=True)
    
    print(f"📁 Исходная папка: {input_path}")
    print(f"📁 Папка для результатов: {output_path}")
    print("=" * 50)
    
    # Ищем все Excel файлы
    excel_files = list(input_path.glob("*.xlsx")) + list(input_path.glob("*.xls"))
    
    if not excel_files:
        print("❌ Excel-файлы не найдены")
        return
    
    print(f"Найдено файлов: {len(excel_files)}\n")
    
    # Счётчики
    processed_count = 0
    skipped_count = 0
    error_count = 0
    
    # Обрабатываем каждый файл
    for file in excel_files:
        try:
            result = process_report(file, output_path)
            if result:
                processed_count += 1
            else:
                skipped_count += 1
        except Exception as e:
            print(f"   ❌ Ошибка при обработке {file.name}: {e}")
            error_count += 1
    
    print("=" * 50)
    print(f"📊 Статистика:")
    print(f"   ✅ Обработано новых файлов: {processed_count}")
    print(f"   ⏭️ Пропущено (уже существуют): {skipped_count}")
    print(f"   ❌ Ошибок: {error_count}")
    print(f"📁 Результаты сохранены в: {output_path}")
    
    return processed_count

def backup_original_files(input_dir, backup_dir=None):
    """
    Создаёт резервную копию оригинальных файлов
    """
    input_path = Path(input_dir)
    
    if backup_dir is None:
        backup_dir = input_path.parent / f"backup_{input_path.name}_{datetime.now().strftime('%Y%m%d_%H%M%S')}"
    else:
        backup_dir = Path(backup_dir)
    
    backup_dir.mkdir(parents=True, exist_ok=True)
    
    excel_files = list(input_path.glob("*.xlsx")) + list(input_path.glob("*.xls"))
    
    for file in excel_files:
        shutil.copy2(file, backup_dir / file.name)
    
    print(f"💾 Резервная копия создана в: {backup_dir}")
    print(f"   Скопировано файлов: {len(excel_files)}")
    return backup_dir

