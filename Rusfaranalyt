def load_sheet_data(file_path, sheet_name):
    """Загружает данные из указанного листа"""
    try:
        df = pd.read_excel(file_path, sheet_name=sheet_name)
        return df
    except Exception as e:
        st.error(f"Ошибка загрузки листа '{sheet_name}': {e}")
        return None

def load_repo_deals(file_path, sheet_name):
    """Загружает сделки репо из листа "Репо"."""
    try:
        df = pd.read_excel(file_path, sheet_name=sheet_name)
        
        if df.columns[0] != 'Дата размещения':
            df.rename(columns={df.columns[0]: 'Дата размещения'}, inplace=True)
        
        if len(df.columns) >= 8:
            df.rename(columns={df.columns[7]: 'Ставка'}, inplace=True)
        
        return df
        
    except Exception as e:
        st.error(f"Ошибка загрузки листа '{sheet_name}': {e}")
        return None

def load_deals_from_row16(file_path, sheet_name):
    """Загружает сделки из файла CF, начиная с 16 строки."""
    try:
        df_raw = pd.read_excel(file_path, sheet_name=sheet_name, header=None)
        
        if len(df_raw) < 16:
            st.warning(f"В файле меньше 16 строк. Найдено: {len(df_raw)}")
            return None
        
        headers_row = df_raw.iloc[15]
        max_row = min(19, len(df_raw))
        data_rows = df_raw.iloc[16:max_row].copy()
        data_rows.columns = headers_row
        
        cols_to_keep = [4, 5, 6, 7]
        col_names = [headers_row.iloc[i] for i in cols_to_keep]
        
        df_result = data_rows.iloc[:, cols_to_keep].copy()
        df_result.columns = col_names
        df_result = df_result.dropna(how='all')
        
        return df_result
        
    except Exception as e:
        st.error(f"Ошибка загрузки сделок из CF: {e}")
        return None

def get_bank_rate(df, column_name):
    """Получает значение ставки банка из указанной колонки"""
    if df is None or df.empty:
        return None
    last_row = df.iloc[-1]
    return last_row.get(column_name, None)

def format_rate(value):
    """Форматирует ставку в процентный вид"""
    if value is None or pd.isna(value):
        return "—"
    if isinstance(value, (int, float)):
        if value < 1:
            return f"{value * 100:.2f}%"
        else:
            return f"{value:.2f}%"
    return str(value)

def get_today_deal(df_deals, is_short_term=True):
    """Находит сделку из данных сделок (из CF)."""
    if df_deals is None or df_deals.empty:
        return None
    
    today = datetime.now().date()
    
    date_start_col = df_deals.columns[2]
    date_end_col = df_deals.columns[3]
    
    df_deals[date_start_col] = pd.to_datetime(df_deals[date_start_col], errors='coerce')
    df_deals[date_end_col] = pd.to_datetime(df_deals[date_end_col], errors='coerce')
    
    df_valid = df_deals.dropna(subset=[date_start_col, date_end_col])
    
    if df_valid.empty:
        return None
    
    df_valid = df_valid.sort_values(by=date_start_col, ascending=False)
    
    for idx, row in df_valid.iterrows():
        if row[date_start_col].date() == today:
            delta = (row[date_end_col] - row[date_start_col]).days
            if is_short_term and delta < 7:
                return row
            elif not is_short_term and delta >= 7:
                return row
    
    for idx, row in df_valid.iterrows():
        delta = (row[date_end_col] - row[date_start_col]).days
        if is_short_term and delta < 7:
            return row
        elif not is_short_term and delta >= 7:
            return row
    
    return None

