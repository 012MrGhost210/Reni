def load_sheet_data(file_path, sheet_name):
    """Загружает данные из указанного листа"""
    try:
        df = pd.read_excel(file_path, sheet_name=sheet_name)
        return df
    except Exception as e:
        st.error(f"Ошибка загрузки листа '{sheet_name}': {e}")
        return None

def load_repo_deals(file_path, sheet_name):
    """Загружает сделки репо из листа "Репо"."""
    try:
        df = pd.read_excel(file_path, sheet_name=sheet_name)
        
        if df.columns[0] != 'Дата размещения':
            df.rename(columns={df.columns[0]: 'Дата размещения'}, inplace=True)
        
        if len(df.columns) >= 8:
            df.rename(columns={df.columns[7]: 'Ставка'}, inplace=True)
        
        return df
        
    except Exception as e:
        st.error(f"Ошибка загрузки листа '{sheet_name}': {e}")
        return None

def load_active_deals_from_log(file_path):
    """Загружает действующие сделки из файла логов (дата окончания >= сегодня)"""
    try:
        if not os.path.exists(file_path):
            return None
        
        df = pd.read_excel(file_path, sheet_name=0)
        if df.empty:
            return None
        
        df['Дата окончания'] = pd.to_datetime(df['Дата окончания'], errors='coerce')
        df = df.dropna(subset=['Дата окончания'])
        
        today = datetime.now().date()
        df_active = df[df['Дата окончания'].dt.date >= today].copy()
        
        return df_active
        
    except Exception as e:
        st.error(f"Ошибка загрузки действующих сделок из лога: {e}")
        return None

def get_bank_rate(df, column_name):
    """Получает значение ставки банка из указанной колонки"""
    if df is None or df.empty:
        return None
    last_row = df.iloc[-1]
    return last_row.get(column_name, None)

def format_rate(value):
    """Форматирует ставку в процентный вид"""
    if value is None or pd.isna(value):
        return "—"
    if isinstance(value, (int, float)):
        if value < 1:
            return f"{value * 100:.2f}%"
        else:
            return f"{value:.2f}%"
    return str(value)

def get_weighted_avg_rate_from_log(file_path, is_short_term=True):
    """
    Рассчитывает средневзвешенную ставку по сегодняшним сделкам из логов.
    is_short_term: True - берём сделки с разницей < 7 дней, False - >= 7 дней
    Возвращает: (средневзвешенная ставка, общая сумма, количество сделок, дата, макс дата окончания)
    """
    try:
        if not os.path.exists(file_path):
            return None, 0, 0, None, None
        
        df = pd.read_excel(file_path, sheet_name=0)
        if df.empty:
            return None, 0, 0, None, None
        
        df['Дата размещения'] = pd.to_datetime(df['Дата размещения'], errors='coerce')
        df['Дата окончания'] = pd.to_datetime(df['Дата окончания'], errors='coerce')
        df = df.dropna(subset=['Дата размещения', 'Дата окончания', 'Ставка (%)', 'Сумма'])
        
        if df.empty:
            return None, 0, 0, None, None
        
        today = datetime.now().date()
        
        # Фильтруем сделки на сегодня
        df_today = df[df['Дата размещения'].dt.date == today].copy()
        
        if df_today.empty:
            return None, 0, 0, None, None
        
        # Фильтруем по длительности
        if is_short_term:
            df_filtered = df_today[(df_today['Дата окончания'] - df_today['Дата размещения']).dt.days < 7].copy()
        else:
            df_filtered = df_today[(df_today['Дата окончания'] - df_today['Дата размещения']).dt.days >= 7].copy()
        
        if df_filtered.empty:
            return None, 0, 0, None, None
        
        # Рассчитываем средневзвешенную ставку
        total_amount = df_filtered['Сумма'].sum()
        weighted_sum = (df_filtered['Ставка (%)'] * df_filtered['Сумма']).sum()
        weighted_avg_rate = weighted_sum / total_amount if total_amount > 0 else None
        
        # Количество сделок
        deals_count = len(df_filtered)
        
        # Дата размещения (сегодня)
        deal_date = today
        
        # Максимальная дата окончания среди сегодняшних сделок
        max_end_date = df_filtered['Дата окончания'].max()
        
        return weighted_avg_rate, total_amount, deals_count, deal_date, max_end_date
        
    except Exception as e:
        st.error(f"Ошибка расчёта средневзвешенной ставки: {e}")
        return None, 0, 0, None, None

