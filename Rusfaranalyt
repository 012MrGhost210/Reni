                            lambda x: f"{x:.2f}%" if isinstance(x, (int, float)) else x
                        )
                    
                    st.dataframe(
                        display_log,
                        use_container_width=True,
                        hide_index=True
                    )
                    st.caption(f"📊 Всего записей в логе: {len(df_log)}")
            except Exception as e:
                st.error(f"Ошибка загрузки лога: {e}")
    
    st.markdown("---")
    if st.button("🔄 Обновить все данные", use_container_width=True):
        st.rerun()
    
    st.caption(f"📁 Основной файл: `{os.path.basename(FILE_PATH_MAIN)}`")
    st.caption(f"📁 Файл RUSFAR: `{os.path.basename(FILE_PATH_RUSFAR)}`")
    st.caption(f"📁 Файл логов сделок: `{os.path.basename(REPO_LOGS_PATH)}`")

if __name__ == "__main__":
    main()
