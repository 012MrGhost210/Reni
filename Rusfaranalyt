# ============ ФУНКЦИИ ДЛЯ RUSFAR API ============

def _get_json(url: str, params: dict):
    try:
        resp = requests.get(url, params=params, headers=HEADERS, timeout=15)
    except requests.exceptions.RequestException as e:
        st.error(f"Ошибка соединения с API Мосбиржи: {e}")
        return None
    if resp.status_code != 200:
        st.error(f"HTTP {resp.status_code}: {resp.text[:200]}")
        return None
    try:
        return resp.json()
    except ValueError:
        st.error(f"Не-JSON ответ: {resp.text[:200]}")
        return None

def get_rates_from_api():
    """Получает ставки RUSFAR через API Мосбиржи"""
    data = _get_json(URL, {
        "iss.meta": "off",
        "securities": ",".join(RUB_TICKERS),
    })
    if not data:
        return {}

    result = {}

    md = data.get("marketdata", {})
    cols = md.get("columns", [])
    for row in md.get("data", []):
        rec = dict(zip(cols, row))
        ticker = rec.get("SECID")
        rate = rec.get("CURRENTVALUE") or rec.get("LASTVALUE")
        if ticker in RUB_TICKERS and rate is not None:
            result[ticker] = {
                "rate": float(rate),
                "date": (rec.get("TRADEDATE") or rec.get("SYSTIME") or "")[:10],
            }

    if not result:
        sec = data.get("securities", {})
        cols = sec.get("columns", [])
        for row in sec.get("data", []):
            rec = dict(zip(cols, row))
            ticker = rec.get("SECID")
            rate = rec.get("CURRENTVALUE") or rec.get("PREVPRICE") or rec.get("LASTVALUE")
            if ticker in RUB_TICKERS and rate is not None:
                result[ticker] = {
                    "rate": float(rate),
                    "date": rec.get("PREVDATE") or rec.get("TRADEDATE") or "",
                }

    return result

def save_rusfar_to_excel(rates: dict, path: str):
    """Сохраняет ставки RUSFAR в Excel-файл"""
    try:
        os.makedirs(os.path.dirname(path), exist_ok=True)
        
        header = ["Дата значения", "Дата выгрузки"] + RUB_TICKERS
        
        if os.path.exists(path):
            wb = load_workbook(path)
            ws = wb.active
        else:
            wb = Workbook()
            ws = wb.active
            ws.title = "RUSFAR"
            ws.append(header)
            for col, w in zip("ABCDEFG", (16, 20, 10, 10, 10, 10, 10)):
                ws.column_dimensions[col].width = w

        value_date = next(iter(rates.values()))["date"]
        existing = {str(row[0].value) for row in ws.iter_rows(min_row=2, max_col=1) if row[0].value}
        
        if value_date in existing:
            st.info(f"Данные за {value_date} уже есть в файле")
        else:
            now = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            ws.append([value_date, now] + [rates.get(t, {}).get("rate") for t in RUB_TICKERS])
            wb.save(path)
            st.success(f"✅ Данные RUSFAR сохранены в файл")
            
    except Exception as e:
        st.error(f"Ошибка сохранения RUSFAR: {e}")

def load_rusfar_from_excel(path: str):
    """Загружает последние значения RUSFAR из Excel-файла"""
    try:
        if not os.path.exists(path):
            return None, None
        
        df = pd.read_excel(path, sheet_name=0)
        if df.empty:
            return None, None
        
        last_row = df.iloc[-1]
        
        rusfar = last_row.get('RUSFAR', None)
        rusfar1w = last_row.get('RUSFAR1W', None)
        
        return rusfar, rusfar1w
        
    except Exception as e:
        st.error(f"Ошибка загрузки RUSFAR из файла: {e}")
        return None, None

